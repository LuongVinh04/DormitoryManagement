      SELECT "r"."Id", "r"."RoomId", "r0"."RoomNumber" AS "roomNumber", "b"."Name" AS "buildingName", "r"."UtilityId", "r"."BillingMonth", CASE
          WHEN "u"."Id" IS NOT NULL THEN "u"."ElectricityNew" - "u"."ElectricityOld"
          ELSE 0
      END AS "electricityUsage", CASE
          WHEN "u"."Id" IS NOT NULL THEN "u"."WaterNew" - "u"."WaterOld"
          ELSE 0
      END AS "waterUsage", "r"."MonthlyRoomFee", "r"."ElectricityFee", "r"."WaterFee", "r"."HygieneFee", "r"."ServiceFee", "r"."InternetFee", "r"."OtherFee", "r"."Total", "r"."PaidAmount", ef_add("r"."Total", ef_negate("r"."PaidAmount")) AS "remainingAmount", "r"."Status", "r"."DueDate", "r"."PaidDate", "r"."PaymentMethod", "r"."PaymentNote", "r"."RecordedBy", "r"."CreatedAt"
      FROM "RoomFinanceRecords" AS "r"
      INNER JOIN "Rooms" AS "r0" ON "r"."RoomId" = "r0"."Id"
      INNER JOIN "Buildings" AS "b" ON "r0"."BuildingId" = "b"."Id"
      LEFT JOIN "Utilities" AS "u" ON "r"."UtilityId" = "u"."Id"
      ORDER BY "r"."BillingMonth" DESC, "r0"."RoomNumber"
